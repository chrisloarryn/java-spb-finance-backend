{
  "info": {
    "_postman_id": "f61a4cf3-7e44-44c3-b6ef-5db1d4b65fb3",
    "name": "Account Transaction",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:1204"
    },
    {
      "key": "clientId",
      "value": "11111111-1111-1111-1111-111111111111"
    },
    {
      "key": "accountId",
      "value": "22222222-2222-2222-2222-222222222222"
    },
    {
      "key": "accountNumber",
      "value": "ACC-1001"
    },
    {
      "key": "reportDate",
      "value": "2026-03-08"
    }
  ],
  "item": [
    {
      "name": "Create Account",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.id) { pm.collectionVariables.set('accountId', json.id); }",
              "if (json.accountNumber) { pm.collectionVariables.set('accountNumber', json.accountNumber); }"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"accountNumber\": \"{{accountNumber}}\",\n  \"initialBalance\": 1000.0,\n  \"status\": true,\n  \"accountType\": \"SAVINGS\",\n  \"clientId\": \"{{clientId}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/api/accounts"
      },
      "response": []
    },
    {
      "name": "List Accounts",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/accounts"
      },
      "response": []
    },
    {
      "name": "Get Account By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/accounts/{{accountId}}"
      },
      "response": []
    },
    {
      "name": "Create Deposit",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"transactionType\": \"SAVINGS\",\n  \"accountNumber\": \"{{accountNumber}}\",\n  \"transactionValue\": 300.0,\n  \"status\": true\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/api/movements"
      },
      "response": []
    },
    {
      "name": "Create Withdrawal",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"transactionType\": \"SAVINGS\",\n  \"accountNumber\": \"{{accountNumber}}\",\n  \"transactionValue\": -120.0,\n  \"status\": true\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/api/movements"
      },
      "response": []
    },
    {
      "name": "List Movements",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/movements"
      },
      "response": []
    },
    {
      "name": "Get Report",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/reports?date={{reportDate}}&clientId={{clientId}}"
      },
      "response": []
    }
  ]
}
