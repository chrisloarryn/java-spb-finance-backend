          "raw": "{\n  \"name\": \"Mary Sutton\",\n  \"clientId\": \"mary-sutton\",\n  \"password\": \"Secret123\",\n  \"gender\": \"Female\",\n  \"age\": 45,\n  \"identifier\": \"mary.sutton@example.com\",\n  \"address\": \"915 Liberty Avenue\",\n  \"phoneNumber\": \"097548965\",\n  \"status\": \"ACTIVE\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/api/clients"
